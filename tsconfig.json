{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules"]
}
